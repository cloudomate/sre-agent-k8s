# ──────────────────────────────────────────
# SRE Agent Environment Configuration
# Copy this to .env and fill in your values
# For Kubernetes deployment, configure k8s/configmap.yaml and k8s/secret.yaml instead.
# ──────────────────────────────────────────

# LLM — any OpenAI-compatible endpoint
# llama.cpp local:    http://localhost:11434/v1  (api_key = "llamacpp")
# llama.cpp in-k8s:  http://llamacpp.sre-agent.svc.cluster.local:11434/v1
# OpenAI:            https://api.openai.com/v1  (api_key = sk-...)
# vLLM:              http://localhost:8000/v1
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=llamacpp
LLM_MODEL=qwen3.5:4b
LLM_EMBED_MODEL=nomic-embed-text
AGENT_MAX_STEPS=12
LLM_TIMEOUT=300

# Kubernetes
# Set K8S_IN_CLUSTER=true when running inside the cluster (uses ServiceAccount token).
# Set K8S_IN_CLUSTER=false for local development (uses KUBECONFIG file).
K8S_IN_CLUSTER=false
KUBECONFIG=~/.kube/config
K8S_NAMESPACE=default

# Log source: kubernetes | loki | journald | file
LOG_BACKEND=kubernetes
LOKI_URL=
LOG_MAX_LINES=200

# Metrics: prometheus | none
METRICS_BACKEND=prometheus
PROMETHEUS_URL=http://localhost:9090
ALERTMANAGER_URL=http://localhost:9093

# Report channels (comma-separated): stdout | file | slack | webhook | email | sms | whatsapp
REPORT_CHANNELS=stdout,file
REPORT_DIR=./reports
RUNBOOK_DIR=./runbooks

# Slack (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Generic webhook for your HCI portal (optional)
REPORT_WEBHOOK_URL=

# SMS / WhatsApp via Twilio (optional — add "sms" and/or "whatsapp" to REPORT_CHANNELS)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM=+15551234567
SMS_TO=+15559876543,+44701234567
WHATSAPP_TO=+15559876543

# Email via SMTP (optional — add "email" to REPORT_CHANNELS)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_TLS=true
SMTP_USER=alerts@example.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=SRE Agent <alerts@example.com>
EMAIL_TO=oncall@example.com,team@example.com

# Kubernetes event watcher (auto-triggers investigations on Warning events)
WATCH_EVENTS=true
WATCH_COOLDOWN_SECONDS=900

# Logging
LOG_LEVEL=INFO
PORT=8080
